# 复制为 ".env" 后再填写真实配置。

# 服务基础配置
APP_NAME=Local Group Report
LISTEN_HOST=0.0.0.0
LISTEN_PORT=18080

# 页面显示配置：grouped=按区服分组，table=普通表格
UI_LAYOUT_MODE=grouped
UI_AUTO_REFRESH_SECONDS=10

# 本地数据存储配置
DB_PATH=local_report.db
PERSIST_REPORTS=false
DELETE_DB_ON_STARTUP=true
DB_CLEAN_INTERVAL_DAYS=0
MAX_REGIONS=0

# 接口鉴权配置：支持请求头 X-Auth-Token，也支持 ?auth_token=
AUTH_TOKEN=

# 企业微信告警配置
ALERT_ENABLED=true
# 超过该秒数未收到上报，判定为超时
ALERT_TIMEOUT_SECONDS=1200
# 后台扫描超时状态的间隔，单位秒
ALERT_CHECK_INTERVAL_SECONDS=10
# 默认告警间隔，单位秒
ALERT_COOLDOWN_SECONDS=360
# 连续超时告警达到该次数后，准备进入低频模式
ALERT_SLOW_MODE_AFTER_COUNT=10
# 连续超时达到该时长后，切换到低频模式，单位秒
ALERT_SLOW_MODE_AFTER_SECONDS=3600
# 低频模式下的告警间隔，单位秒
ALERT_SLOW_MODE_COOLDOWN_SECONDS=1800
# 单个企业微信机器人地址
ALERT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-with-your-key
# 多个企业微信机器人地址，使用逗号分隔
ALERT_WEBHOOK_URLS=
